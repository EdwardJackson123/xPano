{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "xPano",
  "version": "0.1.0",
  "identifier": "com.xpano.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "node scripts/free-port.mjs 1420 && pnpm vite --host 127.0.0.1",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "xPano",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "center": true,
        "backgroundColor": "#0b1014"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../binaries/": "binaries/",
      "../../app.py": "app.py",
      "../../scripts/": "scripts/",
      "../../requirements.txt": "requirements.txt",
      "../../metashape_requirements.txt": "metashape_requirements.txt"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows/nsis-hooks.nsh"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
